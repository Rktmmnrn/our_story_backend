# Database
DATABASE_URL=postgresql+asyncpg://notre_histoire_user:change_me@db:5432/notre_histoire
POSTGRES_USER=notre_histoire_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=notre_histoire

# Security
SECRET_KEY=change_me_with_a_random_64_char_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Storage
MEDIA_ROOT=/app/media
MAX_PHOTO_SIZE_MB=20
MAX_VIDEO_SIZE_MB=500
MAX_AUDIO_SIZE_MB=50

# Initial Admin
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change_me_admin

# App Configuration
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@notrehistoire.app